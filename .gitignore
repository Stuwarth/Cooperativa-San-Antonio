# ═══════════════════════════════════════════════════════════════
# SMAT-SR · .gitignore
# Solo se sube al repositorio: backend/, frontend/, y docs.
# ═══════════════════════════════════════════════════════════════

# ── Dependencias ──────────────────────────────────────────────
node_modules/
package-lock.json

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*

# ── Build output (se regenera con npm run build) ─────────────
frontend/dist/

# ── Variables de entorno ──────────────────────────────────────
.env
.env.local
.env.*.local

# ── IDEs y editores ───────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── SO ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IA / Skills / Agentes (NO deben verse en el repo) ────────
.gemini/
.agents/
SKILLS_TEMP/

# ── Archivos personales / temporales del equipo ──────────────
CONTEXTO_COMPLETO_IA.md
HISTORIAL_CONVERSACION.md
INFORME_TECNICO.md
Professional Frontend UX_UI Implementation.md
extract_history.js
*.jpeg
*.zip

# ── Carpetas de documentación interna (NO son código) ────────
INFORME PROYECTO FINAL/
PRESENTACION DEFENSA/

# ── Misc ──────────────────────────────────────────────────────
*.tgz
*.tsbuildinfo
coverage/
.nyc_output/
.cache/
.parcel-cache/

# ── Root-level package (solo es para pptxgenjs temporal) ─────
/package.json
/package-lock.json
